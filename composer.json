{
    "name": "sistema-facturacion/sv",
    "description": "Sistema de Facturación Electrónica - El Salvador",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "slim/slim": "4.*",
        "slim/psr7": "1.*",
        "firebase/php-jwt": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "platform-check": false,
        "allow-plugins": {
            "php-http/discovery": true
        },
        "audit": {
            "ignore": ["[\"PKSA-y2cr-5h3j-g3ys\"]"],
            "block-insecure": false
        }
    }
}
